# Environment configuration for CrewAI Multi-Agent Book Generator
# DO NOT commit the actual .env file containing real keys.

# OpenAI API key (required for LLM agents)
OPENAI_API_KEY=your_openai_api_key_here

# Serper API key (required for Web Search tool)
SERPER_API_KEY=your_serper_api_key_here

# Application mode (development, production)
APP_ENV=development

# Optional human checkpoints
HUMAN_REVIEW_OUTLINE=true
HUMAN_REVIEW_DRAFT=true
