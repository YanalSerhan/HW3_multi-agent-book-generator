# ==============================================================================
# CrewAI Multi-Agent Book Generator — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# ==============================================================================

# ---------- LLM Configuration ----------

# OpenAI API Key (required)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use for agents
# Recommended: gpt-4o (best quality), gpt-4o-mini (cost-effective)
OPENAI_MODEL=gpt-4o

# LLM temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# Maximum tokens per LLM response
LLM_MAX_TOKENS=4096

# ---------- Search Configuration ----------

# Serper API Key for web search (optional — falls back to DuckDuckGo)
# Get yours at: https://serper.dev/
SERPER_API_KEY=

# Maximum search results per query
MAX_SEARCH_RESULTS=10

# Maximum total sources to collect
MAX_SOURCES=30

# ---------- Pipeline Configuration ----------

# Topic for the book/article
TOPIC=Multi-Agent Systems in AI: Theoretical Foundations and Modern Applications

# Output directory (relative to project root)
OUTPUT_DIR=output

# LaTeX output directory (relative to project root)
LATEX_DIR=output/latex

# Document type: "article" or "book"
DOCUMENT_TYPE=book

# Target word count for the document
TARGET_WORD_COUNT=15000

# Maximum retry attempts for failed stages
MAX_RETRIES=3

# ---------- Quality Gates ----------

# Minimum Flesch readability score (0-100, higher = easier to read)
MIN_READABILITY_SCORE=60.0

# Minimum number of verified citations
MIN_CITATION_COUNT=15

# Minimum number of pages in the final PDF
MIN_PAGES=20

# ---------- Human-in-the-Loop ----------

# Set to "true" to pause for human review after outline generation
HUMAN_REVIEW_OUTLINE=false

# Set to "true" to pause for human review after first draft
HUMAN_REVIEW_DRAFT=false

# ---------- Logging ----------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log output format: "json" (structured) or "console" (human-readable)
LOG_FORMAT=json
